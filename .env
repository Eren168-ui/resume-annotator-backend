# ── 必填 ──────────────────────────────────────────────────────────────────────

# 当前推荐：阿里云百炼 OpenAI 兼容接口（先填你自己的百炼 API Key）
AI_PROVIDER=openai
OPENAI_API_KEY=sk-f254c0165c3643e2bafc9eb06349045a
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
OPENAI_MODEL=qwen-vl-max-latest
OPENAI_FALLBACK_MODELS=qwen-vl-max-2025-08-13,qwen-vl-plus-latest,qwen-vl-plus-2025-08-15,qwen-vl-plus-2025-05-07,qwen-vl-plus

# 百炼结构化输出兼容：默认 auto 即可；需要强制时可改成 true/false
OPENAI_JSON_SCHEMA_OMIT_MAX_TOKENS=auto

# OCR 模型先保留做工具预留，当前不接入主批注链路
# OCR_FALLBACK_MODEL=qwen-vl-ocr-latest

# 旧的 Claude / 中转配置先保留，后续如需切回可直接取消注释
# AI_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-EBrxreYtDdAKJQ2G6TJ4JcfUJRLJqwl59Sv39gFbhYvv9A6M
# OPENAI_BASE_URL=https://oneapi.hk/
# OPENAI_MODEL=claude-4.6-opus-medium

# JWT 签名密钥（随机字符串，生产必须换掉）
JWT_SECRET=WHSmQivxWNC_WttGq0gER_gZ021FIL9TPyLJUbxi5Zk

# 管理员账号（MVP 固定账号）
ADMIN_EMAIL=admin@erenlab.cn
ADMIN_PASSWORD=1120240241.

# ── 可选 ──────────────────────────────────────────────────────────────────────

# 数据和文件存储根目录（默认 ./data）
DATA_DIR=./data

# 前端域名（用于 CORS）
FRONTEND_ORIGIN=http://localhost:5173
LOG_LEVEL=DEBUG
DEV_AUTH_BYPASS=true

# JWT 有效期（秒，默认 86400 = 24 小时）
JWT_EXPIRE_SECONDS=86400

# 处理脚本路径（默认自动定位到 ../bootstrap/scripts/resume-review-annotator-v2.py）
# ANNOTATOR_SCRIPT=/absolute/path/to/resume-review-annotator-v2.py

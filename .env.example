# ══════════════════════════════════════════════════════════════════
# AI Provider 选择
# ══════════════════════════════════════════════════════════════════
# 通过 AI_PROVIDER 切换大模型服务商。支持: openai | claude
AI_PROVIDER=openai

# ──────────────────────────────────────────────────────────────────
# 方案 A：直连 OpenAI 官方
# ──────────────────────────────────────────────────────────────────
# OPENAI_BASE_URL 不填时默认走官方 https://api.openai.com
OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com   # 可省略
# OPENAI_MODEL=gpt-4o-mini                 # 默认值，可改为 gpt-4o 等

# ──────────────────────────────────────────────────────────────────
# 方案 B：通过 OneAPI / 中转代理（推荐国内使用）
# ──────────────────────────────────────────────────────────────────
# 填你的中转地址（不含 /v1）：
# OPENAI_BASE_URL=https://your-oneapi.example.com
# OPENAI_API_KEY=sk-your-oneapi-key-here       ← 填中转平台给的 Key，不是官方 Key
# OPENAI_MODEL=gpt-4o-mini                     ← 填中转平台支持的模型名

# 示例（OneAPI 默认端口 3000）：
# OPENAI_BASE_URL=http://localhost:3000
# OPENAI_BASE_URL=https://api.your-domain.com

# ──────────────────────────────────────────────────────────────────
# 方案 C：使用 Anthropic Claude
# ──────────────────────────────────────────────────────────────────
# AI_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# ANTHROPIC_MODEL=claude-opus-4-6         # 或 claude-sonnet-4-6
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # 默认值，可省略

# ══════════════════════════════════════════════════════════════════
# 服务端配置（所有 provider 都必填）
# ══════════════════════════════════════════════════════════════════

# JWT 签名密钥（生产必须换成随机长字符串）
JWT_SECRET=change-me-in-production-use-a-long-random-string

# 管理员账号
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# ══════════════════════════════════════════════════════════════════
# 可选高级配置
# ══════════════════════════════════════════════════════════════════

# 数据存储根目录（默认 ./data）
# DATA_DIR=./data

# 前端域名（CORS）
# 单个域名：
# FRONTEND_ORIGIN=http://localhost:5173
# 多个域名（逗号分隔，适合同时允许 apex / www）：
# FRONTEND_ORIGINS=https://erenlab.cn,https://www.erenlab.cn

# JWT 有效期（秒，默认 86400 = 24h）
# JWT_EXPIRE_SECONDS=86400

# 简历最大处理页数（默认 2）
# MAX_RESUME_PAGES=2

# PDF 转图片 DPI（默认 180）
# RENDER_DPI=180

# annotator 脚本绝对路径（默认自动定位）
# ANNOTATOR_SCRIPT=/path/to/resume-review-annotator-v2.py
